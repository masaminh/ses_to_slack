{
  "name": "ses_to_slack",
  "version": "0.1.0",
  "bin": {
    "ses_to_slack": "bin/ses_to_slack.js"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run --coverage",
    "pretest": "NODE_ENV=test AWS_DEFAULT_REGION=us-east-1 npm run synth > /dev/null",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy:prod": "NODE_ENV=production AWS_DEFAULT_REGION=us-east-1 cdk deploy",
    "deploy:dev": "NODE_ENV=develop AWS_DEFAULT_REGION=us-east-1 cdk deploy",
    "destroy:prod": "NODE_ENV=production AWS_DEFAULT_REGION=us-east-1 cdk destroy",
    "destroy:dev": "NODE_ENV=develop AWS_DEFAULT_REGION=us-east-1 cdk destroy"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/config": "4.4.0",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "aws-cdk": "^2.1132.0",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-flat-gitignore": "^2.3.0",
    "neostandard": "^0.13.0",
    "ts-node": "^10.9.2",
    "typescript": "~7.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@aws-cdk/assert": "^2.68.0",
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/client-sqs": "^3.1086.0",
    "aws-cdk-lib": "^2.260.0",
    "config": "^4.4.1",
    "constructs": "^10.7.0",
    "mailparser": "^3.9.14",
    "source-map-support": "^0.5.21"
  }
}
