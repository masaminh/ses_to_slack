{
  "name": "ses_to_slack",
  "version": "0.1.0",
  "bin": {
    "ses_to_slack": "bin/ses_to_slack.js"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run --coverage",
    "pretest": "NODE_ENV=test AWS_DEFAULT_REGION=us-east-1 npm run synth > /dev/null",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy:prod": "NODE_ENV=production AWS_DEFAULT_REGION=us-east-1 cdk deploy",
    "deploy:dev": "NODE_ENV=develop AWS_DEFAULT_REGION=us-east-1 cdk deploy",
    "destroy:prod": "NODE_ENV=production AWS_DEFAULT_REGION=us-east-1 cdk destroy",
    "destroy:dev": "NODE_ENV=develop AWS_DEFAULT_REGION=us-east-1 cdk destroy"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/config": "3.3.3",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.19.39",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.5",
    "aws-cdk": "^2.1119.0",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-flat-gitignore": "^2.1.0",
    "neostandard": "^0.13.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-cdk/assert": "^2.68.0",
    "@aws-sdk/client-s3": "^3.1040.0",
    "@aws-sdk/client-sqs": "^3.1040.0",
    "aws-cdk-lib": "^2.245.0",
    "config": "^3.3.12",
    "constructs": "^10.4.4",
    "mailparser": "^3.9.8",
    "source-map-support": "^0.5.21",
    "uuid": "^14.0.0"
  }
}
